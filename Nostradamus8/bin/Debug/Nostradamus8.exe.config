<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5" />
    </startup>
  <appSettings>
    <add key="LogDir" value="MyLogs"/>
    <add key="ShouldLog" value="true"/>
    
  </appSettings>
  <system.serviceModel>
    <bindings>
      <basicHttpBinding>
        <binding name="BasicHttpBinding_INostraSrv" />
      </basicHttpBinding>
    </bindings>
    <client>
      <endpoint address="http://localhost:7280/NostradamusSrv.svc"
        binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_INostraSrv"
        contract="NostraSrv.INostraSrv" name="BasicHttpBinding_INostraSrv" />
    </client>
  </system.serviceModel>
</configuration>